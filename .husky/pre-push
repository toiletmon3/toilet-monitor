#!/bin/sh
# TypeScript check before every push — blocks push if there are errors

echo "🔍 Checking TypeScript (server)..."
cd apps/server && npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors in server — push blocked"
  exit 1
fi

echo "🔍 Checking TypeScript (web)..."
cd ../web && npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors in web — push blocked"
  exit 1
fi

echo "✅ TypeScript OK — pushing"
