generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// MULTI-TENANT ORGANIZATIONS
// =============================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{\"defaultLanguage\":\"he\",\"rateLimit\":300,\"autoResolveAfterHours\":24}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings       Building[]
  properties      Property[]
  users           User[]
  issueTypes      IssueType[]
  kioskTemplates  KioskTemplate[]

  @@map("organizations")
}

// =============================================
// LOCATION HIERARCHY
// =============================================

model KioskTemplate {
  id        String  @id @default(uuid())
  orgId     String
  name      String
  isDefault Boolean @default(false)
  theme     String  @default("default") // "default" | "neon" | "neon-pro" | "neon-image" | "neon-video"
  buttons   Json
  iconScale Float   @default(1.5) // kiosk icon/label size multiplier (1 = 100%)
  ledSnake  Boolean @default(false) // animated LED "snake" light around the tiles
  statsLayout Json? // neon-image overlay positions: { usersNum:{top,right}, periodWord:{top,right}, minutesNum:{top,right} } in % of stage

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  buildings    Building[]
  devices      Device[]

  @@map("kiosk_templates")
}

// A property (נכס) groups buildings — e.g. a country club with several
// buildings. Sits between the organization and its buildings, and is the
// scope a PROPERTY_MANAGER is confined to.
model Property {
  id    String @id @default(uuid())
  orgId String
  name  String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  buildings    Building[]
  users        User[]
  managers     User[]       @relation("ManagedProperties")

  @@map("properties")
}

model Building {
  id               String  @id @default(uuid())
  orgId            String
  propertyId       String?
  name             String
  address          String  @default("")
  latitude         Float?
  longitude        Float?
  kioskTemplateId  String?

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property      Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  kioskTemplate KioskTemplate? @relation(fields: [kioskTemplateId], references: [id])
  floors        Floor[]
  cleaners      User[]

  @@map("buildings")
}

model Floor {
  id          String @id @default(uuid())
  buildingId  String
  floorNumber Int
  name        String

  building  Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  restrooms Restroom[]

  @@unique([buildingId, floorNumber])
  @@map("floors")
}

model Restroom {
  id      String        @id @default(uuid())
  floorId String
  name    String
  gender  Gender        @default(UNISEX)
  status  RestroomStatus @default(ACTIVE)

  floor        Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  devices      Device[]
  incidents    Incident[]
  sensorEvents SensorEvent[]

  @@map("restrooms")
}

// =============================================
// DEVICES (tablets, sensors)
// =============================================

model Device {
  id              String     @id @default(uuid())
  restroomId      String
  deviceCode      String     @unique
  type            DeviceType @default(KIOSK)
  kioskTemplateId String?
  lastHeartbeat   DateTime?
  lastHost        String? // domain the tablet last sent a heartbeat through (cleanco.ai / duckdns)
  hostsSeen       Json? // { "<host>": "<ISO last heartbeat>" } — all domains with recent heartbeats
  isOnline        Boolean    @default(false)
  createdAt       DateTime   @default(now())

  restroom      Restroom       @relation(fields: [restroomId], references: [id], onDelete: Cascade)
  kioskTemplate KioskTemplate? @relation(fields: [kioskTemplateId], references: [id], onDelete: SetNull)
  incidents     Incident[]
  sensorEvents  SensorEvent[]

  @@map("devices")
}

// Presence transitions reported by radar sensors (HLK-LD2450 bridges).
// presence_start = someone entered an empty restroom; presence_end = it
// emptied out, durationSec covering the whole occupied stretch (one
// "visit" for analytics/cleaning triggers).
model SensorEvent {
  id          String   @id @default(uuid())
  deviceId    String
  restroomId  String
  type        String // presence_start / presence_end
  durationSec Int?
  targets     Int?
  createdAt   DateTime @default(now())

  device   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  restroom Restroom @relation(fields: [restroomId], references: [id], onDelete: Cascade)

  @@index([restroomId, createdAt])
  @@map("sensor_events")
}

// Device codes an admin deleted. Kiosk URLs are public and ROOM-* codes
// self-register, so without this a deleted tablet resurrects itself on the
// next page load. A blocked code is refused everywhere until an admin
// re-registers the tablet through the kiosk selector.
model BlockedDeviceCode {
  deviceCode String   @id
  blockedAt  DateTime @default(now())

  @@map("blocked_device_codes")
}

// =============================================
// USERS
// =============================================

model CleanerArrival {
  id         String    @id @default(uuid())
  userId     String
  restroomId String?
  buildingId String?
  arrivedAt  DateTime  @default(now())
  leftAt     DateTime?
  note       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cleaner_arrivals")
}

model User {
  id            String   @id @default(uuid())
  orgId         String
  buildingId    String?
  propertyId    String? // PROPERTY_MANAGER scope; also set on users a property manager creates
  idNumber      String
  name          String
  email         String?
  phone         String?
  role          UserRole @default(CLEANER)
  passwordHash  String?
  preferredLang String   @default("he")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building          Building?        @relation(fields: [buildingId], references: [id])
  property          Property?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  managedProperties Property[]       @relation("ManagedProperties") // PROPERTY_MANAGER: the properties they manage
  incidentActions   IncidentAction[]
  assignedIncidents Incident[]       @relation("AssignedCleaner")
  arrivals          CleanerArrival[]
  pushSubscriptions PushSubscription[]

  @@unique([orgId, idNumber])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  orgId     String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// =============================================
// ISSUE TYPES
// =============================================

model IssueType {
  id       String  @id @default(uuid())
  orgId    String?
  code     String
  nameI18n Json    // { "he": "נייר טואלט", "en": "Toilet Paper" }
  icon     String  @default("📋")
  priority Int     @default(3) // 1=highest
  isActive Boolean @default(true)

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  incidents    Incident[]

  @@unique([orgId, code])
  @@map("issue_types")
}

// =============================================
// INCIDENTS (core entity)
// =============================================

model Incident {
  id               String         @id @default(uuid())
  clientId         String         @unique // device-generated UUID for dedup
  restroomId       String
  issueTypeId      String
  deviceId         String
  assignedCleanerId String?
  status           IncidentStatus @default(OPEN)
  reportedAt       DateTime       // device timestamp
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime       @default(now()) // server receipt time

  restroom        Restroom       @relation(fields: [restroomId], references: [id])
  issueType       IssueType      @relation(fields: [issueTypeId], references: [id])
  device          Device         @relation(fields: [deviceId], references: [id])
  assignedCleaner User?          @relation("AssignedCleaner", fields: [assignedCleanerId], references: [id])
  actions         IncidentAction[]

  @@index([restroomId, status])
  @@index([reportedAt])
  @@index([status, reportedAt])
  @@map("incidents")
}

model IncidentAction {
  id          String     @id @default(uuid())
  clientId    String?    @unique // for offline dedup
  incidentId  String
  userId      String?
  actionType  ActionType
  notes       String?
  performedAt DateTime   // device timestamp

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@map("incident_actions")
}

// =============================================
// ENUMS
// =============================================

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum RestroomStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum DeviceType {
  KIOSK
  SENSOR
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  MANAGER
  PROPERTY_MANAGER
  SHIFT_SUPERVISOR
  CLEANER
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ActionType {
  REPORTED
  ACKNOWLEDGED
  RESOLVED
  ESCALATED
}
