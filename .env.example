# =============================================
# COPY THIS FILE TO .env AND FILL IN VALUES
# =============================================

# Database
POSTGRES_PASSWORD="yourpassword"
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/toilet_monitor"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Admin default credentials (change after first login)
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="ChangeMe123!"

# Web Push / VAPID (generate once with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)")
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Email (Gmail API over HTTPS — no SMTP port needed)
# Setup: https://console.cloud.google.com → Create OAuth2 credentials
# Then use OAuth2 Playground to get a refresh token with scope https://mail.google.com/
GMAIL_USER="toiletmon3@gmail.com"
GMAIL_CLIENT_ID="your-google-oauth2-client-id"
GMAIL_CLIENT_SECRET="your-google-oauth2-client-secret"
GMAIL_REFRESH_TOKEN="your-google-oauth2-refresh-token"
SMTP_FROM="toiletmon3@gmail.com"

# Cron secret — used by GitHub Actions to call /api/email/generate-report
CRON_SECRET="generate-a-random-string-here"
